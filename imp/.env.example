# =============================================================================
# Project 16 — Real-Time Streaming Data Lake
# ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# HOW TO USE:
#   1. Copy this file to imp/.env  (same folder, different name)
#   2. Replace every <placeholder> value with real credentials
#   3. NEVER commit imp/.env to git (already in .gitignore)
#
# Values here are PLACEHOLDERS ONLY — safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# CONFLUENT CLOUD (Kafka) — Phase 2
# -----------------------------------------------------------------------------
# Sign up: https://confluent.cloud/ (free tier, no credit card for basic cluster)
# After creating a cluster, generate API keys from the cluster settings page.
CONFLUENT_BOOTSTRAP_SERVERS=<your-cluster>.<region>.<cloud>.confluent.cloud:9092
CONFLUENT_API_KEY=<your-cluster-api-key>
CONFLUENT_API_SECRET=<your-cluster-api-secret>

# Schema Registry (separate API keys from the cluster keys)
CONFLUENT_SCHEMA_REGISTRY_URL=https://<your-sr>.<region>.<cloud>.confluent.cloud
CONFLUENT_SCHEMA_REGISTRY_API_KEY=<your-sr-api-key>
CONFLUENT_SCHEMA_REGISTRY_API_SECRET=<your-sr-api-secret>

# Kafka topic name for our simulated viewer events
KAFKA_TOPIC_USER_EVENTS=user-events

# -----------------------------------------------------------------------------
# AWS (S3 data lake storage) — Phase 3
# -----------------------------------------------------------------------------
# Create an IAM user with programmatic access and S3 full access (dev-only).
# Generate access keys from IAM -> Users -> Security credentials.
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION=ap-south-1
AWS_S3_BUCKET=project16-streaming-data-lake

# -----------------------------------------------------------------------------
# DATABRICKS (Spark runtime) — Phase 3
# -----------------------------------------------------------------------------
# Databricks Community Edition: https://community.cloud.databricks.com/
# Host: your workspace URL (e.g., https://community.cloud.databricks.com)
# Token: User Settings -> Developer -> Access tokens -> Generate new token
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=<your-databricks-pat>

# -----------------------------------------------------------------------------
# SNOWFLAKE (warehouse) — Phase 5
# -----------------------------------------------------------------------------
# Sign up: https://signup.snowflake.com/  (30-day free trial, $400 credit)
# Account locator is in your Snowflake URL: <account>.<region>.snowflakecomputing.com
SNOWFLAKE_ACCOUNT=<your-account-locator>
SNOWFLAKE_USER=<your-snowflake-username>
SNOWFLAKE_PASSWORD=<your-snowflake-password>
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=PROJECT16_DB
SNOWFLAKE_SCHEMA=GOLD
SNOWFLAKE_ROLE=ACCOUNTADMIN

# -----------------------------------------------------------------------------
# GRAFANA (monitoring dashboard) — Phase 7
# -----------------------------------------------------------------------------
# Used when we spin up Grafana locally via Docker Compose in Phase 7.
# Pick any strong password — nothing is pre-assigned.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<choose-a-strong-password>
